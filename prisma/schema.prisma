generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TradeDirection {
  LONG
  SHORT
}

enum TradeStatus {
  OPEN
  CLOSED
  WATCHLIST
}

model Asset {
  id                String      @id @default(cuid())
  ticker            String      @unique
  name              String
  assetClass        String
  region            String
  sector            String
  currency          String
  themes            Json
  allocationBucket  String
  price             Float
  changePct         Float
  volumeScore       Int
  momentumScore     Int
  trendScore        Int
  relativeScore     Int
  volatilityScore   Int
  valuationScore    Int
  macroFitScore     Int
  geoFitScore       Int
  liquidityScore    Int
  catalystScore     Int
  opportunityScore  Int
  technicalSetup    Json
  technicalInsight  Json
  executionPlan     Json
  catalyst          String
  direction         TradeDirection
  stopDistancePct   Float
  conviction        Int
  shortThesis       String
  regimeFitText     String
  macroReasons      Json
  geopoliticalNotes Json
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model Holding {
  id               String   @id @default(cuid())
  ticker           String   @unique
  name             String
  assetClass       String
  sector           String
  region           String
  currency         String
  themes           Json
  allocationBucket String
  quantity         Float
  avgCost          Float
  marketPrice      Float
  marketValueAed   Float
  unrealizedPnlAed Float
  weightPct        Float
  beta             Float
  correlationTag   String
  stopDistancePct  Float
  openRiskAed      Float
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model WatchlistItem {
  id                   String   @id @default(cuid())
  ticker               String   @unique
  name                 String
  assetClass           String
  sector               String
  region               String
  currency             String
  themes               Json
  priority             String
  targetEntry          String
  thesis               String
  candidateAllocationPct Float
  candidateBucket      String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model MacroEvent {
  id            String   @id @default(cuid())
  title         String
  region        String
  eventDate     DateTime
  severity      String
  severityScore Int
  category      String
  consensus     String
  implication   String
  watchFor      String
  explanation   String
  createdAt     DateTime @default(now())
}

model GeopoliticalEvent {
  id                  String   @id @default(cuid())
  title               String
  category            String
  region              String
  severity            String
  severityScore       Int
  status              String
  affectedRegions     Json
  transmissionChannels Json
  beneficiaries       Json
  losers              Json
  actionSuggestion    String
  chips               Json
  implication         String
  createdAt           DateTime @default(now())
}

model JournalEntry {
  id                 String      @id @default(cuid())
  ticker             String
  setupName          String
  direction          TradeDirection
  status             TradeStatus
  openedAt           DateTime
  closedAt           DateTime?
  entryPrice         Float
  exitPrice          Float?
  thesis             String
  outcomeR           Float?
  disciplineScore    Int
  mistakeTag         String?
  reviewNotes        String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
