DATABASE_URL="postgresql://user:password@localhost:5432/mdb_journal"
ALPHA_VANTAGE_API_KEY=""

# Jarvis — TWO ways to run, pick one:
#
# 1) RECOMMENDED for production / deploy: Anthropic-direct (works on Vercel, ships with the PWA)
ANTHROPIC_API_KEY=""
#
# 2) Optional local dev: OpenJarvis sidecar (multi-engine, scheduler, memory) — see jarvis-sidecar/README.md
#    Used as a fallback when ANTHROPIC_API_KEY is empty.
JARVIS_BASE_URL="http://localhost:8000"

# Required for Jarvis tool callbacks regardless of path
JARVIS_SHARED_SECRET="change-me-jarvis-shared-secret"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
